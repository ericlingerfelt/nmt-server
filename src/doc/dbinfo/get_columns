# 
# This is a simple script that queries the mysql databases, gets the table
# information and then uses the 'format_it.awk' script to format the results
# into html files.  the last little bit changes the date in the 'index.html'
# file. The only files that should be placed into CVS are this file, the awk
# script, the index.html file and 'masses.png' which is the graphic.
#########################################################################
dbnames="mass_model mysql information_schema "
if [ -e "index_names.txt" ]; then
  if unlink "index_names.txt"; then echo -e "removed index_names.txt\n";fi
fi
for t in $dbnames
do
  if [ -e $t'_desc.txt' ]; then
    echo "file exists: $t'_desc.txt'"
    if unlink $t'_desc.txt'; then echo -e "removed file\n"; fi
   # touch $i_desc.txt
  fi

  tables=`mysqlshow -u root -pkdh4956jh $t | sed -e 's/[-|+]//g' -e 's/Database: '$t'//' -e 's/Tables //' | tr -s ' '`
  echo $tables

  for i in $tables
    do
      name=`echo $i | sed 's/_/\\_/g'`
      echo -e "######\n\n" >> $t'_desc.txt'
      #echo $name
      mysqlshow -u root -pkdh4956jh $t "$name" '%' >> $t'_desc.txt'
    done

  echo -e "######\n\n" >> $t'_desc.txt'
  echo -e $t"\n" >> index_names.txt

  ./format_it.awk $t'_desc.txt' > $t'_desc.html'
done
# clean up a little.
cp -f index.sav index.html
./create_index.awk index_names.txt db_comments.sav >> index.html

/bin/rm -f *.txt

# This next bit updates the updated date in the index.html file
# That is the one html that is NOT generated by the scripts although
# it could be, but what is the point? Point is that if db's are added or
# dropped the page needs to be updated

today=`date +'%d %b %Y'`
ed -s index.html << END
/update/s/: .*</: $today</
w
q
END

